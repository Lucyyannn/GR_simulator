{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Simulator (SSD fast)",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/Simulator",
      "args": [
        "--config", "${workspaceFolder}/configs/systolic_ws_128x128_c4_simple_noc_tpuv4_half_ramulator2_ssd_fast.json",
        "--models_list", "${workspaceFolder}/example/models_list.json",
        "--log_level", "debug"
      ],
      "cwd": "${workspaceFolder}",
      "environment": [
        {"name": "ONNXIM_HOME", "value": "${workspaceFolder}"}
      ],
      "preLaunchTask": "build"
    },
    {
      "name": "Simulator (SSD realistic)",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/Simulator",
      "args": [
        "--config", "${workspaceFolder}/configs/systolic_ws_128x128_c4_simple_noc_tpuv4_half_ramulator2_ssd.json",
        "--models_list", "${workspaceFolder}/example/models_list.json",
        "--log_level", "info"
      ],
      "cwd": "${workspaceFolder}",
      "environment": [
        {"name": "ONNXIM_HOME", "value": "${workspaceFolder}"}
      ],
      "preLaunchTask": "build"
    },
    {
      "name": "Simulator (no SSD)",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/Simulator",
      "args": [
        "--config", "${workspaceFolder}/configs/systolic_ws_128x128_c4_simple_noc_tpuv4_half_ramulator2.json",
        "--models_list", "${workspaceFolder}/example/models_list.json",
        "--log_level", "info"
      ],
      "cwd": "${workspaceFolder}",
      "environment": [
        {"name": "ONNXIM_HOME", "value": "${workspaceFolder}"}
      ],
      "preLaunchTask": "build"
    },
    {
      "name": "Simulator_test",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/Simulator_test",
      "args": [],
      "cwd": "${workspaceFolder}",
      "environment": [
        {"name": "ONNXIM_HOME", "value": "${workspaceFolder}"}
      ],
      "preLaunchTask": "build"
    }
  ]
}
